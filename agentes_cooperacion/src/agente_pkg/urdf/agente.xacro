<?xml version="1.0"?>
<robot name="agent_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- parametros -->
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.02"/>
  <xacro:property name="base_size" value="0.3"/>

  <xacro:property name="half_base" value="${base_size/2}"/>
  <xacro:property name="wheel_y" value="${half_base + 0.03}"/>
  <xacro:property name="wheel_x" value="${half_base}"/>

  <!-- base del robot -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_size} ${base_size} 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- rueda izquierda anterior-->
  <link name="left_wheel_a">
    <visual>
      <origin rpy="1.57 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- rueda izquierda posterior-->
  <link name="left_wheel_p">
    <visual>
      <origin rpy="1.57 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- rueda derecha anterior-->
  <link name="right_wheel_a">
    <visual>
      <origin rpy="1.57 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/> 
      </geometry>
      <material name="black">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- rueda derecha posterior -->
  <link name="right_wheel_p">
    <visual>
      <origin rpy="1.57 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/> 
      </geometry>
      <material name="black">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- joint rueda izquierda-anterior-base -->
  <joint name="left_wheel_joint_a" type="continuous"> 
    <parent link="base_link"/>
    <child link="left_wheel_a"/>
    <origin xyz="${wheel_x} ${wheel_y} -${wheel_radius}"/>
    <axis xyz="0 1 0"/> 
  </joint>

  <!-- joint rueda izquierda-posterior-base -->
  <joint name="left_wheel_joint_p" type="continuous"> 
    <parent link="base_link"/>
    <child link="left_wheel_p"/>
    <origin xyz="-${wheel_x} ${wheel_y} -${wheel_radius}"/>
    <axis xyz="0 1 0"/> 
  </joint>

  <!-- joint rueda derecha-anterior-base -->
  <joint name="right_wheel_joint_a" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_a"/>
    <origin xyz="${wheel_x} -${wheel_y} -${wheel_radius}"/>
    <axis xyz="0 1 0"/> 
  </joint> 

   <!-- joint rueda derecha-posterior-base -->
  <joint name="right_wheel_joint_p" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_p"/>
    <origin xyz="-${wheel_x} -${wheel_y} -${wheel_radius}"/>
    <axis xyz="0 1 0"/> 
  </joint> 
</robot>
